PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
MONGODB_URI=mongodb+srv://[user]:[pass]@cluster0.xxxxx.mongodb.net/cipherlink?retryWrites=true&w=majority
UPSTASH_REDIS_REST_URL=https://[db].upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
UPSTASH_REDIS_URL=rediss://default:[pass]@[host]:[port]
JWT_SECRET=generate-with-node-crypto-64-chars
JWT_REFRESH_SECRET=generate-with-node-crypto-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=https://realtime-encrypted-messenger.vercel.app
