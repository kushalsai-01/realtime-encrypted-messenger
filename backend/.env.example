# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SERVER_ID=local                    # Unique per pod in K8s (auto-set from pod name)

# ── PostgreSQL (Supabase in prod, local Docker in dev) ───────────────────────
DATABASE_URL=postgresql://cipherlink:password@localhost:5432/cipherlink

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/cipherlink?retryWrites=true&w=majority

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# REST API (used for: JWT blacklist, presence, offline queue, rate limiting)
UPSTASH_REDIS_REST_URL=https://YOURDB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token-here

# IORedis URL (used for: pub/sub cross-pod message routing)
# For local dev with docker-compose: redis://redis:6379
# For Upstash: rediss://default:PASSWORD@HOST:PORT
UPSTASH_REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# MUST be at least 32 characters. MUST be different from each other.
JWT_SECRET=generate-with-openssl-rand-base64-64
JWT_REFRESH_SECRET=generate-with-openssl-rand-base64-64-DIFFERENT
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# For local dev: http://localhost:5173
# For prod: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ── Optional ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
