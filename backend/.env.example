# ── Required ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SERVER_ID=local

DATABASE_URL=postgresql://cipherlink:password@localhost:5432/cipherlink
MONGODB_URI=mongodb+srv://[user]:[pass]@cluster0.xxxxx.mongodb.net/cipherlink?retryWrites=true&w=majority

UPSTASH_REDIS_REST_URL=https://[db].upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
UPSTASH_REDIS_URL=rediss://default:[pass]@[host]:[port]

JWT_SECRET=generate-with-openssl-rand-base64-64-minimum-32-chars
JWT_REFRESH_SECRET=generate-with-openssl-rand-base64-64-different-from-above
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

# ── Optional ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
